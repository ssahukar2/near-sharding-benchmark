+def _apply_json_patches_local(args):
+    """Apply genesis/config/log patches per neard home under ~/.near/local-mocknet/."""
+    lm = local_test_node.DEFAULT_LOCAL_MOCKNET_DIR.resolve()
+    bench = pathlib.Path(BENCHNET_DIR).expanduser().resolve()
+    case_dir = bench / args.case
+    base_genesis = (case_dir / args.bm_params["base_genesis_patch"]).resolve()
+    base_config = (case_dir / args.bm_params["base_config_patch"]).resolve()
+    config_patch = (case_dir / "config_patch.json").resolve()
+    log_patch = (bench / "cases" / "log_patch.json").resolve()
+    json_updater = bench / "helpers" / "json_updater.py"
+    for name in args.forknet_details["cp_instance_names"]:
+        near_home = lm / name / ".near"
+        genesis = near_home / "genesis.json"
+        config = near_home / "config.json"
+        log_config = near_home / "log_config.json"
+        cmd = (
+            f"python3 {json_updater} {genesis} {base_genesis} && "
+            f"python3 {json_updater} {config} {base_config} {config_patch} && "
+            f"touch {log_config} && "
+            f"python3 {json_updater} {log_config} {log_patch}"
+        )
+        if args.forknet_details.get("tracing_server_internal_ip") is None:
+            cmd += (
+                f" && jq '.opentelemetry = null' {log_config} >tmp.$$.json && "
+                f"mv tmp.$$.json {log_config} || rm tmp.$$.json"
+            )
+        run_cmd_args = copy.deepcopy(args)
+        run_cmd_args.host_filter = name
+        run_cmd_args.cmd = cmd
+        run_remote_cmd(CommandContext(run_cmd_args))
+
