+def _upload_json_patches_local(args):
+    bench = pathlib.Path(BENCHNET_DIR).expanduser()
+    bench.mkdir(parents=True, exist_ok=True)
+    src_cases = pathlib.Path(SOURCE_BENCHNET_DIR).expanduser().resolve() / "cases"
+    dst_cases = bench / "cases"
+    if dst_cases.is_dir():
